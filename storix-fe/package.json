{
  "name": "storix-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build --webpack",
    "start": "next start -H 0.0.0.0",
    "build:capacitor": "CAPACITOR_BUILD=true next build --webpack",
    "cap:sync": "CAPACITOR_BUILD=true cap sync ios",
    "ios": "npm run build:capacitor && npm run cap:sync && CAPACITOR_BUILD=true cap open ios",
    "ios:dev": "cap sync ios && cap open ios",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@stomp/stompjs": "^7.2.1",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@team-lepisode/capacitor-naver-login": "^7.0.0",
    "axios": "^1.13.2",
    "capacitor-kakao-login-plugin": "^3.0.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-intersection-observer": "^10.0.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
